# PostgreSQL connection URL. For SSL connections, explicitly specify sslmode=verify-full
# Example: postgresql://user:password@host:port/dbname?sslmode=verify-full
DATABASE_URL=

# Certification Module
CERT_SIGNING_SECRET=                      # 64-char hex — generate: openssl rand -hex 32
CERT_STORAGE_BUCKET=scholarx-certificates # S3 or Cloudflare R2 bucket name
CERT_STORAGE_ENDPOINT=                    # R2 endpoint URL (omit for AWS S3)
CERT_STORAGE_ACCESS_KEY_ID=
CERT_STORAGE_SECRET_ACCESS_KEY=
CERT_BASE_URL=https://scholarx.lk        # Base URL for verify/claim links
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=   # Base URL of your app

SMTP_HOST=
SMTP_PORT=
SMTP_EMAIL=
SMTP_PASSWORD=


NODE_ENV=development
# Development-only auth bypass (ignored outside NODE_ENV=development)
DEV_AUTH_BYPASS=false
# Optional: "user" (default) or "admin"
DEV_AUTH_BYPASS_ROLE=user
